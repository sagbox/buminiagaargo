# ============================================================
# Bumi Niaga Agrochem — Production Environment Variables
# Copy this file to .env and fill in real values
# Usage: cp .env.production.example .env
# ============================================================

# === DATABASE (AWS RDS PostgreSQL) ===
DB_URL_USER=jdbc:postgresql://YOUR-RDS-ENDPOINT.ap-southeast-1.rds.amazonaws.com:5432/buminiaga?currentSchema=user_schema
DB_URL_PRODUCT=jdbc:postgresql://YOUR-RDS-ENDPOINT.ap-southeast-1.rds.amazonaws.com:5432/buminiaga?currentSchema=product_schema
DB_URL_ORDER=jdbc:postgresql://YOUR-RDS-ENDPOINT.ap-southeast-1.rds.amazonaws.com:5432/buminiaga?currentSchema=order_schema
DB_URL_PAYMENT=jdbc:postgresql://YOUR-RDS-ENDPOINT.ap-southeast-1.rds.amazonaws.com:5432/buminiaga?currentSchema=payment_schema
DB_USER=buminiaga_app
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# === JWT Authentication ===
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING_HERE

# === AWS S3 & CloudFront (product images) ===
AWS_ACCESS_KEY=AKIA_YOUR_ACCESS_KEY
AWS_SECRET_KEY=YOUR_SECRET_KEY
AWS_S3_BUCKET=buminiagaagrochem-assets
AWS_CLOUDFRONT_URL=https://d1234567.cloudfront.net
AWS_REGION=ap-southeast-1

# === Midtrans Payment Gateway ===
# Sandbox keys for testing (change to production keys when ready)
MIDTRANS_SERVER_KEY=SB-Mid-server-YOUR_KEY
MIDTRANS_CLIENT_KEY=SB-Mid-client-YOUR_KEY
MIDTRANS_PRODUCTION=false

# === CORS ===
# Set to your EC2 public IP or domain
ALLOWED_ORIGIN=http://YOUR_EC2_PUBLIC_IP
