# JANGAN commit file ini ke git setelah diisi dengan nilai nyata!
# Copy ke app-secrets.yaml, isi nilai, lalu apply dengan:
#   kubectl apply -f infrastructure/k8s/secrets/app-secrets.yaml -n buminiaga
#
# ATAU buat dari .env file:
#   kubectl create secret generic app-secrets --from-env-file=.env -n buminiaga

apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: buminiaga
type: Opaque
stringData:
  DB_URL: "jdbc:postgresql://YOUR-RDS-ENDPOINT:5432/buminiaga"
  DB_USER: "postgres"
  DB_PASSWORD: "YOUR-DB-PASSWORD"
  JWT_SECRET: "YOUR-JWT-SECRET-MIN-32-CHARS"
  AWS_ACCESS_KEY: "YOUR-AWS-ACCESS-KEY"
  AWS_SECRET_KEY: "YOUR-AWS-SECRET-KEY"
  AWS_S3_BUCKET: "buminiagaagrochem-assets"
  AWS_CLOUDFRONT_URL: "https://YOUR-DISTRIBUTION.cloudfront.net"
  MIDTRANS_SERVER_KEY: "YOUR-MIDTRANS-SERVER-KEY"
  MIDTRANS_CLIENT_KEY: "YOUR-MIDTRANS-CLIENT-KEY"
  MIDTRANS_PRODUCTION: "false"
