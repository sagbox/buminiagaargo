# Copy file ini menjadi .env dan isi dengan nilai yang benar
# cp .env.example .env

# JWT - Ganti dengan string random minimal 32 karakter
JWT_SECRET=buminiaga-super-secret-key-ganti-ini-sekarang!!

# AWS
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_S3_BUCKET=buminiagaagrochem-assets
AWS_CLOUDFRONT_URL=https://your-distribution.cloudfront.net

# Midtrans (dapatkan dari dashboard.midtrans.com)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxx
MIDTRANS_PRODUCTION=false

# Frontend allowed origin
ALLOWED_ORIGIN=http://localhost:5173
